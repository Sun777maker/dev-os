# ============================================================
# ContractIQ — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase (public — safe to expose to the browser) ───────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (private — server-side only, never NEXT_PUBLIC_) ─
# Used exclusively inside createAdminClient() for rate limiting.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (private — server-side only) ─────────────────────
OPENAI_API_KEY=sk-...

# ── Chat security ────────────────────────────────────────────
# Maximum number of prior messages sent to the model per request.
# Reducing this lowers cost and latency. Default: 100.
MAX_CHAT_HISTORY=100
